generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ProductLayout {
  id        String   @id @default(cuid())
  productId Int
  branchId  Int
  zone      String   @default("dry")
  groupId   String?
  x         Float
  y         Float
  color     String   @default("#3b82f6")
  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())

  @@unique([branchId, zone, productId])
}
